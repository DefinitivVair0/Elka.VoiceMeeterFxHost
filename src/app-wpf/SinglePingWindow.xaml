<Window x:Class="Elka.VoiceMeeterFxHost.App.SinglePingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Single Ping"
        Width="520"
        Height="330"
        MinWidth="480"
        MinHeight="300"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="130" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <TextBlock Grid.Row="0"
               Grid.ColumnSpan="2"
               Text="Single Ping"
               FontSize="20"
               FontWeight="SemiBold"
               Foreground="{StaticResource DelayAccentBrush}"
               Margin="0,0,0,14" />

    <TextBlock Grid.Row="1"
               Grid.Column="0"
               Text="Ping input"
               FontWeight="SemiBold"
               VerticalAlignment="Center" />
    <ComboBox x:Name="PingInputComboBox"
              Grid.Row="1"
              Grid.Column="1"
              Margin="0,0,0,10"
              SelectionChanged="EndpointComboBox_SelectionChanged" />

    <TextBlock Grid.Row="2"
               Grid.Column="0"
               Text="Return output"
               FontWeight="SemiBold"
               VerticalAlignment="Center" />
    <ComboBox x:Name="ReturnOutputComboBox"
              Grid.Row="2"
              Grid.Column="1"
              Margin="0,0,0,10"
              SelectionChanged="EndpointComboBox_SelectionChanged" />

    <Border Grid.Row="3"
            Grid.ColumnSpan="2"
            Background="{StaticResource FieldBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">
      <TextBlock x:Name="ResultTextBlock"
                 Text="Ready."
                 TextWrapping="Wrap"
                 Style="{StaticResource MutedText}" />
    </Border>

    <Grid Grid.Row="4"
          Grid.ColumnSpan="2"
          Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock x:Name="SelectionTextBlock"
                 Grid.Column="0"
                 VerticalAlignment="Center"
                 Style="{StaticResource MutedText}" />
      <Button Grid.Column="1"
              Content="Ping"
              Width="90"
              Style="{StaticResource RouteButton}"
              Click="PingButton_Click" />
      <Button Grid.Column="2"
              Content="Close"
              Width="90"
              Margin="8,0,0,0"
              Click="CloseButton_Click" />
    </Grid>
  </Grid>
</Window>
