<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>$(RepoRoot)\artifacts\publish\ElkaVoiceMeeterFxHost\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <ElkaCreateReleaseArtifacts>true</ElkaCreateReleaseArtifacts>
    <ElkaUploadGitHubRelease>true</ElkaUploadGitHubRelease>
    <GitHubRepository Condition="'$(GitHubRepository)' == ''">torment78/Elka.VoiceMeeterFxHost</GitHubRepository>
    <GitHubReleaseTag Condition="'$(GitHubReleaseTag)' == ''">v$(Version)</GitHubReleaseTag>
    <ReleaseDir>$(RepoRoot)\artifacts\release\</ReleaseDir>
    <PublishOutputDir>$(RepoRoot)\artifacts\publish\ElkaVoiceMeeterFxHost\win-x64\</PublishOutputDir>
    <PublishedExePath>$(RepoRoot)\artifacts\publish\ElkaVoiceMeeterFxHost\win-x64\Elka.VoiceMeeterFxHost.App.exe</PublishedExePath>
    <ReleaseExePath>$(RepoRoot)\artifacts\release\ElkaVoiceMeeterFxHost.exe</ReleaseExePath>
    <ReleaseZipPath>$(RepoRoot)\artifacts\release\ElkaVoiceMeeterFxHost-win-x64-framework-dependent.zip</ReleaseZipPath>
    <ReleaseUploadLogPath>$(RepoRoot)\artifacts\release\github-upload.log</ReleaseUploadLogPath>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
