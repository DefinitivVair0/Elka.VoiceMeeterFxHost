<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>..\..\artifacts\publish\ElkaVoiceMeeterFxHost\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <ElkaCreateReleaseArtifacts>true</ElkaCreateReleaseArtifacts>
    <ElkaUploadGitHubRelease>true</ElkaUploadGitHubRelease>
    <GitHubReleaseTag Condition="'$(GitHubReleaseTag)' == ''">v$(Version)</GitHubReleaseTag>
    <ReleaseDir>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\..\..\artifacts\release'))\</ReleaseDir>
    <PublishOutputDir>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\$(PublishDir)'))\</PublishOutputDir>
    <PublishedExePath>$(PublishOutputDir)Elka.VoiceMeeterFxHost.App.exe</PublishedExePath>
    <ReleaseExePath>$(ReleaseDir)ElkaVoiceMeeterFxHost.exe</ReleaseExePath>
    <ReleaseZipPath>$(ReleaseDir)ElkaVoiceMeeterFxHost-$(RuntimeIdentifier)-framework-dependent.zip</ReleaseZipPath>
  </PropertyGroup>

  <Target Name="ElkaAfterPublishReleaseArtifacts"
          AfterTargets="Publish"
          Condition="'$(ElkaCreateReleaseArtifacts)' == 'true'">
    <Message Importance="high" Text="Creating Elka release artifacts in $(ReleaseDir)" />
    <MakeDir Directories="$(ReleaseDir)" />
    <Copy SourceFiles="$(PublishedExePath)"
          DestinationFiles="$(ReleaseExePath)"
          OverwriteReadOnlyFiles="true" />
    <Delete Files="$(ReleaseZipPath)" Condition="Exists('$(ReleaseZipPath)')" />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;Compress-Archive -Path '$(PublishOutputDir)*' -DestinationPath '$(ReleaseZipPath)' -Force&quot;" />
    <Message Importance="high" Text="Release EXE: $(ReleaseExePath)" />
    <Message Importance="high" Text="Release ZIP: $(ReleaseZipPath)" />
  </Target>

  <Target Name="ElkaUploadGitHubRelease"
          AfterTargets="ElkaAfterPublishReleaseArtifacts"
          Condition="'$(ElkaUploadGitHubRelease)' == 'true'">
    <Message Importance="high" Text="Uploading Elka release artifacts to GitHub release $(GitHubReleaseTag)" />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$tag='$(GitHubReleaseTag)'; if ([string]::IsNullOrWhiteSpace($tag)) { throw 'GitHubReleaseTag is empty.' }; gh release view $tag *&gt; $null; if ($LASTEXITCODE -ne 0) { gh release create $tag --title $tag --notes 'Elka VoiceMeeter FX Host $(GitHubReleaseTag)' }; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; gh release upload $tag '$(ReleaseZipPath)' '$(ReleaseExePath)' --clobber; exit $LASTEXITCODE&quot;" />
  </Target>
</Project>
