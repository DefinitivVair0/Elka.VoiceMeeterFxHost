<Window x:Class="Elka.VoiceMeeterFxHost.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elka VoiceMeeter FX Host"
        Icon="Assets/VoicemeeterDelay.ico"
        Width="1600"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="22">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Orientation="Horizontal">
        <Border Width="62"
                Height="62"
                Margin="0,0,14,0"
                Background="Transparent"
                CornerRadius="8">
          <Image Source="Assets/VoicemeeterDelayIconPreview.png"
                 Stretch="Uniform"
                 RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Elka VoiceMeeter FX Host"
                     FontSize="26"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="MixerTypeTextBlock"
                     Text="Voicemeeter Potato profile"
                     Margin="0,3,0,0"
                     Style="{StaticResource MutedText}" />
        </StackPanel>
      </StackPanel>

      <Border x:Name="EngineStatusBorder"
              Grid.Column="1"
              Background="{StaticResource StatusIdleBrush}"
              CornerRadius="6"
              MinWidth="330"
              MaxWidth="520"
              Padding="12,6"
              VerticalAlignment="Center">
        <TextBlock x:Name="StatusTextBlock"
                   Text="Starting native engine..."
                   FontWeight="SemiBold"
                   TextAlignment="Center"
                   Style="{StaticResource MutedText}" />
      </Border>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="545" />
        <ColumnDefinition Width="18" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <ScrollViewer Grid.Column="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Style="{StaticResource PanelCard}" Margin="0,0,0,16">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         Text="Side"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold" />
              <StackPanel Grid.Row="0"
                          Grid.Column="1"
                          Orientation="Horizontal"
                          Margin="0,0,0,12">
                <Button x:Name="InputModeButton"
                        Content="Input"
                        Width="92"
                        Click="InputModeButton_Click" />
                <Button x:Name="OutputModeButton"
                        Content="Output"
                        Width="92"
                        Margin="8,0,0,0"
                        Click="OutputModeButton_Click" />
                <Button x:Name="MainModeButton"
                        Content="Main"
                        Width="92"
                        Margin="8,0,0,0"
                        Click="MainModeButton_Click" />
              </StackPanel>

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Text="I/O"
                         VerticalAlignment="Top"
                         Margin="0,6,0,0"
                         FontWeight="SemiBold" />
              <WrapPanel x:Name="EndpointButtonsPanel"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,0,12" />

            </Grid>
          </Border>

          <Border Style="{StaticResource PanelCard}"
                  BorderBrush="{StaticResource RouteAccentBrush}"
                  Margin="0,0,0,16">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="VST Routing"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource RouteAccentBrush}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Add Node"
                        Width="92"
                        Style="{StaticResource RouteButton}"
                        Click="AddNodeButton_Click" />
              </Grid>

              <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Search"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox x:Name="PluginSearchTextBox"
                         Grid.Column="1"
                         TextChanged="PluginSearchTextBox_TextChanged" />
                <Button Grid.Column="2"
                        Content="Scan"
                        Width="72"
                        Margin="8,0,0,0"
                        Style="{StaticResource RouteButton}"
                        Click="ScanButton_Click" />
              </Grid>


              <ListBox x:Name="PluginListBox"
                       Grid.Row="2"
                       Height="132"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       MouseDoubleClick="PluginListBox_MouseDoubleClick" />

              <StackPanel x:Name="VstNodesPanel"
                          Grid.Row="3"
                          Margin="0,10,0,0" />
            </Grid>
          </Border>

          <Border x:Name="CrossRoutingBorder"
                  Style="{StaticResource PanelCard}"
                  BorderBrush="{StaticResource RouteAccentBrush}"
                  Margin="0,0,0,16"
                  Visibility="Collapsed">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0"
                         Text="Cross Routing"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource RouteAccentBrush}"
                         Margin="0,0,0,8" />
              <TextBlock x:Name="CrossRouteSummaryTextBlock"
                         Grid.Row="1"
                         Style="{StaticResource MutedText}"
                         Margin="0,0,0,10" />
              <StackPanel x:Name="CrossRoutePanel"
                          Grid.Row="2" />
            </Grid>
          </Border>

          <Border Style="{StaticResource PanelCard}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         Text="Tools"
                         FontSize="18"
                         FontWeight="SemiBold" />
              <Button Grid.Row="0"
                      Grid.Column="1"
                      Content="Single Ping"
                      Width="112"
                      Click="SinglePingButton_Click" />
              <TextBlock x:Name="RouteSummaryTextBlock"
                         Grid.Row="1"
                         Grid.ColumnSpan="2"
                         Margin="0,10,0,8"
                         Style="{StaticResource MutedText}" />
              <TextBox x:Name="LogTextBox"
                       Grid.Row="2"
                       Grid.ColumnSpan="2"
                       Height="110"
                       FontFamily="Consolas"
                       FontSize="13"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto" />
            </Grid>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Column="2"
              Style="{StaticResource PanelCard}"
              Padding="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="14,12,14,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="RoutingCanvasTitleTextBlock"
                       Text="Routing Canvas"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource RouteAccentBrush}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <Button x:Name="ChannelsWorkspaceButton"
                      Content="Channels"
                      Width="92"
                      Style="{StaticResource RouteButton}"
                      Click="ChannelsWorkspaceButton_Click" />
              <Button x:Name="VstWorkspaceButton"
                      Content="VST"
                      Width="74"
                      Margin="8,0,0,0"
                      Style="{StaticResource RouteButton}"
                      Click="VstWorkspaceButton_Click" />
              <Button Content="Save"
                      Width="74"
                      Margin="8,0,0,0"
                      Click="SaveButton_Click" />
              <Button Content="Refresh"
                      Width="74"
                      Margin="8,0,0,0"
                      Click="RefreshCanvasButton_Click" />
            </StackPanel>
          </Grid>

          <Border x:Name="VstWorkspaceView"
                  Grid.Row="1"
                  Margin="14,0,14,14"
                  Background="{StaticResource FieldBrush}"
                  BorderBrush="{StaticResource SubtleBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <Canvas x:Name="RoutingCanvas"
                      Width="980"
                      Height="920"
                      Background="{StaticResource FieldBrush}"
                      MouseMove="RoutingCanvas_MouseMove"
                      MouseLeftButtonUp="RoutingCanvas_MouseLeftButtonUp" />
            </ScrollViewer>
          </Border>

          <Grid x:Name="ChannelsWorkspaceView"
                Grid.Row="1"
                Margin="14,0,14,14"
                Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="12" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource FieldBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
              <ScrollViewer HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ChannelStripPanel"
                            Orientation="Horizontal"
                            MinHeight="248" />
              </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource FieldBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
              <ScrollViewer HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="CrossRouteCanvas"
                        Width="980"
                        Height="560"
                        Background="{StaticResource FieldBrush}"
                        MouseMove="CrossRouteCanvas_MouseMove"
                        MouseLeftButtonUp="CrossRouteCanvas_MouseLeftButtonUp" />
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
